                        <PaddingTop>2pt</PaddingTop>
                        <PaddingBottom>2pt</PaddingBottom>
                      </Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>
                <TablixCell>
                  <CellContents>
                    <Textbox Name="QuoteInstallRate2">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>=Sum(Fields!QuoteInstallRate.Value)</Value>
                              <Style>
                                <FontFamily>Roboto</FontFamily>
                                <FontSize>8pt</FontSize>
                                <Color>=iif(Fields!QuoteInstallRate.Value &lt; Fields!BudInstallRate.Value*80/100, "DarkBlue",
	iif(Fields!QuoteInstallRate.Value &gt; Fields!BudInstallRate.Value*120/100,"DarkRed","Black")
)</Color>
                              </Style>
                            </TextRun>
                          </TextRuns>
                          <Style>
                            <TextAlign>Right</TextAlign>
                          </Style>
                        </Paragraph>

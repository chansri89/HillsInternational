                <TablixCell>
                  <CellContents>
                    <Textbox Name="Textbox3">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>=Fields!OnlyAmountValue.Value+Fields!InstallAmount.Value+Fields!SupplyAmount.Value</Value>
                              <Style>
                                <FontFamily>Roboto</FontFamily>
                                <FontSize>8pt</FontSize>
                                <Format>0;(0)</Format>
                                <Color>=iif(Fields!Quantity.Value * (Fields!QuoteOnlyRate.Value+Fields!QuoteSupplyRate.Value+Fields!QuoteInstallRate.Value)
&gt; 1.20*Fields!Quantity.Value *(Fields!BudOnlyRate.Value+Fields!BudSupplyRate.Value+Fields!BudInstallRate.Value), "DarkRED",
iif(Fields!Quantity.Value * (Fields!QuoteOnlyRate.Value+Fields!QuoteSupplyRate.Value+Fields!QuoteInstallRate.Value)
&lt;0.80*Fields!Quantity.Value *(Fields!BudOnlyRate.Value+Fields!BudSupplyRate.Value+Fields!BudInstallRate.Value),"DarkBlue","Black")
)</Color>
                              </Style>
                            </TextRun>
                          </TextRuns>
                          <Style>
                            <TextAlign>Right</TextAlign>
                          </Style>
                        </Paragraph>
                      </Paragraphs>

                              <Value>=Sum(Fields!QuoteSupplyRate.Value)</Value>
                              <Style>
                                <FontFamily>Roboto</FontFamily>
                                <FontSize>8pt</FontSize>
                                <Color>=iif(Fields!QuoteSupplyRate.Value &lt; Fields!BudSupplyRate.Value*80/100, "DarkBlue",
	iif(Fields!QuoteSupplyRate.Value &gt; Fields!BudSupplyRate.Value*120/100,"DarkRed","Black")
)</Color>
                              </Style>
                            </TextRun>
                          </TextRuns>
                          <Style>
                            <TextAlign>Right</TextAlign>
                          </Style>
                        </Paragraph>
                      </Paragraphs>

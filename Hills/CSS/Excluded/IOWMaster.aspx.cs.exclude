    #region IOWItem
    private void LoadddlItem()//To load data into grid.
    {
        if (ddlCompany.SelectedIndex > 0) //&& ddlItemCategory.SelectedIndex > 0 && ddlItemSubCategory.SelectedIndex > 0)
        {
            ItemMsg Cmp = new ItemMsg();
            Cmp.Flag = "R";
            Cmp.CreatedBy = BaseMsg.EmployeeCode;
            Cmp.CompanyId = Convert.ToInt32(ddlCompany.SelectedValue);
            //if (ddlItemCategory.SelectedIndex == 0)
            //{
            Cmp.ItemCategoryId = 0;
            //}
            //else
            //{
            //    Cmp.ItemCategoryId = Convert.ToInt32(ddlItemCategory.SelectedValue);
            //}
            //if (ddlItemSubCategory.SelectedIndex == 0)
            //{
            Cmp.ItemSubCategoryId = 0;
            //}
            //else
            //{
            //     Cmp.ItemSubCategoryId = Convert.ToInt32(ddlItemSubCategory.SelectedValue);
            //}
           // List<ItemMsg> ITList = Bus.MasItemMasterInsertUpdateandDelete(Cmp);
            ITList = Bus.MasItemMasterInsertUpdateandDelete(Cmp);
            ddlLoadItem(ITList);
        }
        else
        {
            ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + "Pls Select Company " + "');", true);
            Pnlgv.Visible = false;
            pnlAdd.Visible = false;
        }
    }
    private void ddlLoadItem(List<ItemMsg> ITList)
    {
        ddlItem.DataSource = ITList;
        ddlItem.DataBind();
        ddlItem.Items.Insert(0, "--Select Please--");
        ddlItem.SelectedIndex = 0;
        ddlItem.Enabled = true;
    }
    private void IOWItemFetch(Int32 WCompanyId, string IOWCode)
    {
        pnlAdd.Visible = false;
        Pnlgv.Visible = false;
        pnlIOWItem.Visible = true;
        pnlIOWitemAdd.Visible = true;
        List<IOWItemMsg> IOWItlst = Bus.MasCRAMIOWItemSelectSp(WCompanyId, IOWCode);
        LoadGridItem(IOWItlst);
        LoadddlItem();
        foreach (IOWItemMsg iwt in IOWItlst)
        {
            txtIOWcd.Text = iwt.IOWCode;
            txtIOWNm.Text = iwt.IOWName;
            break;
        }
        txtItemQty.Text = "";
        txtItemUOM.Text = "";
        txtWastage.Text = "";

    }
    private void LoadGridItem(List<IOWItemMsg> IOWItlst)
    {
        grdIOWItem.DataSource = "";
        grdIOWItem.DataSource = IOWItlst;
        grdIOWItem.DataBind();
    }
    private void btnAddclick()
    { //Load grid to list and add the item and then reload the Grid
        List<IOWItemMsg> IowItemLst = new List<IOWItemMsg>();
        IowItemLst = LoadGridToList();
        AddItemSelected(IowItemLst);
        pnlItemAddClear();
    }
    private void btnUpdateClick()
    {
        // Load to list.. delete the Item in Grid .. Modify the list and reload to grid
        List<IOWItemMsg> IowItemLst = new List<IOWItemMsg>();
        IowItemLst = LoadGridToList();    
        AddItemSelected(IowItemLst);
        pnlItemAddClear();
    }
    private void pnlItemAddClear()
    {
        txtItemCode.Text = "";
        txtItemUOM.Text = "";
        chkIsItemImported.Checked = false;
        ddlItem.SelectedIndex = 0;
        //txtIOWcd.Text = "";
        //txtIOWNm.Text = "";
    }
    private void AddItemSelected(List<IOWItemMsg> IowItemLst)
    {
        Int32 WItemId = Convert.ToInt32(ddlItem.SelectedValue);
       
        IOWItemMsg iwm = new IOWItemMsg();
        iwm.CompanyId = Convert.ToInt32(ddlCompany.SelectedValue);
        iwm.IOWCode = txtIOWcd.Text;
        iwm.IOWName = txtIOWNm.Text;
        iwm.ItemId = Convert.ToInt32(ddlItem.SelectedValue);
        // get ItemCode and IsImported for selected Item
            LoadddlItem();
            ddlItem.SelectedValue = WItemId.ToString();
            foreach (ItemMsg im in ITList)
            {
                if (im.ItemId == WItemId)
                {
                    iwm.ItemName = im.ItemName;
                    iwm.ItemCode = im.ItemCode; 
                    iwm.ItemUOM = im.ItemUOM;
                    iwm.IsImported = im.IsImported;
                   
                    break;
                }
            }
        //
        iwm.ItemQuantity = Convert.ToDouble(txtItemQty.Text);
        iwm.Wastage = Convert.ToDouble(txtWastage.Text);
        IowItemLst.Add(iwm);

        LoadGridItem(IowItemLst);
    }
   
    private void DelIOWItem(string WIOWItemID)
    {
        List<IOWItemMsg> IowItemLst = new List<IOWItemMsg>();
        foreach (GridViewRow gvr in grdIOWItem.Rows)
        {
            if (((Label)gvr.FindControl("lblItemId")).Text == WIOWItemID)
            {
                //do not include the item in list and populate the grid --indicating item deleted
            }
            else
            {
                IOWItemMsg iwm = new IOWItemMsg();
                iwm.CompanyId = Convert.ToInt32(((Label)gvr.FindControl("lblCompanyId")).Text);
                iwm.IOWCode = (((Label)gvr.FindControl("lblIOWCode")).Text);
                iwm.IOWName = (((Label)gvr.FindControl("lblIOWName")).Text);
                iwm.ItemId = Convert.ToInt32(((Label)gvr.FindControl("lblItemId")).Text);
                iwm.ItemCode = (((Label)gvr.FindControl("lblItemCode")).Text);
                iwm.ItemName = (((Label)gvr.FindControl("lblItemName")).Text);
                iwm.ItemUOM = (((Label)gvr.FindControl("lblItemUOM")).Text);
                iwm.ItemQuantity = Convert.ToDouble(((Label)gvr.FindControl("lblItemQty")).Text);
                iwm.Wastage = Convert.ToDouble(((Label)gvr.FindControl("lblWastage")).Text);
                iwm.IsImported = (((CheckBox)gvr.FindControl("chkIsImported")).Checked);
                IowItemLst.Add(iwm);
            }

        }
        LoadGridItem(IowItemLst);
    }
    private List<IOWItemMsg> LoadGridToList()
    {
        List<IOWItemMsg> IOWItlst = new List<IOWItemMsg>();
        foreach (GridViewRow gvr in grdIOWItem.Rows)
        {
            IOWItemMsg iwm = new IOWItemMsg();
            iwm.CompanyId = Convert.ToInt32(((Label)gvr.FindControl("lblCompanyId")).Text);
            iwm.IOWCode = (((Label)gvr.FindControl("lblIOWCode")).Text);
            iwm.IOWName = (((Label)gvr.FindControl("lblIOWName")).Text);
            iwm.ItemId = Convert.ToInt32(((Label)gvr.FindControl("lblItemId")).Text);
            iwm.ItemCode = (((Label)gvr.FindControl("lblItemCode")).Text);
            iwm.ItemName = (((Label)gvr.FindControl("lblItemName")).Text);
            iwm.ItemUOM = (((Label)gvr.FindControl("lblItemUOM")).Text);
            iwm.ItemQuantity = Convert.ToDouble(((Label)gvr.FindControl("lblItemQty")).Text);
            iwm.Wastage = Convert.ToDouble(((Label)gvr.FindControl("lblWastage")).Text);
            iwm.IsImported = (((CheckBox)gvr.FindControl("chkIsImported")).Checked);
            IOWItlst.Add(iwm);
        }
        return IOWItlst;
    }
    private void IOWItemInsertUpdate(List<IOWItemMsg> it)
    {
        List<IOWItemMsg> IOWit = Bus.MasCRAMIOWItemInsertUpdate(it,BaseMsg.EmployeeCode);
        foreach (IOWItemMsg iwm in IOWit)
        {
            if (iwm.Result.Substring(0, 1) == "0")
            {
                ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + AgilerMail.SuccessFullySaved + "');", true);
                pnlAdd.Visible = false;
                Pnlgv.Visible = false;
                pnlIOWItem.Visible = true;
                pnlIOWitemAdd.Visible = true;
                btnSave.Text = "Save";
                break;

            }
            else
            {
                ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + iwm.Result + "');", true);
                break;
            }
        }
        //pnlIOWItem.Visible = false;
        //pnlIOWitemAdd.Visible = false;
    }


    private void IOWItemsave()
    {
        pnlAdd.Visible = false;
        Pnlgv.Visible = false;
        pnlIOWItem.Visible = true;
        pnlIOWitemAdd.Visible = true;
    }
    #endregion

    #region Validation
    private int IsValidSave()
    {
        int Error = 0;
        string DisplayError = "";
        if (txtIOWCode.Text.Trim() == "" || Convert.ToInt32(txtIOWCode.Text.Trim().Length) == 0)
        {
            DisplayError = DisplayError + " IOWCode is Mandatory .";
            //ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + AgilerMail.ErrorIOWCode + "');", true);
            Error = 1;
        }
        if (txtIOWName.Text.Trim() == "" || Convert.ToInt32(txtIOWName.Text.Trim().Length) == 0)
        {
            DisplayError = DisplayError + "--" + " IOW Name is Mandatory . ";
            // ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + AgilerMail.ErrorIOWName + "');", true);
            Error = 1;
        }
        if (txtIOWUOM.Text.Trim() == "" || Convert.ToInt32(txtIOWUOM.Text.Trim().Length) == 0)
        {
            DisplayError = DisplayError + "--" + " UOM is Mandatory . ";

            Error = 1;
        }

        if (txtIOWQuantity.Text.Trim() == "" || Convert.ToInt32(txtIOWQuantity.Text.Trim().Length) == 0)
        {
            DisplayError = DisplayError + "--" + " IOW Quantity is Mandatory . ";
            // ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + AgilerMail.ErrorIOWShortName + "');", true);
            Error = 1;
        }
        //if (txtStandardRate.Text.Trim() == "" || Convert.ToInt32(txtStandardRate.Text.Trim().Length) == 0)
        //{
        //    DisplayError = DisplayError + "--" + " IOW Standard Rate is Mandatory . ";
        //    // ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + AgilerMail.ErrorIOWShortName + "');", true);
        //    Error = 1;
        //}

        try
        {
            Double Qty = Convert.ToDouble(txtIOWQuantity.Text);
           
        }
        catch
        {
            DisplayError = DisplayError + "--" + " IOW Quantity to be numeric  . ";
            Error = 1;
        }
       

        if (Error == 1)
        {
            ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + DisplayError + "');", true);
        }
        return Error;
    }
    private int IsValidAdd()
    {
        int Error = 0;
        string DisplayError = "";
        if (ddlItem.SelectedIndex == 0)
        {
            DisplayError = DisplayError + "--" + " Item Is Mandatory pls Select .... ";
            Error = 1;
        }

        if (txtItemQty.Text.Trim() == "" || Convert.ToInt32(txtItemQty.Text.Trim().Length) == 0)
        {
            DisplayError = DisplayError + "--" + " Item Quantity is Mandatory . ";
            Error = 1;
        }
        try
        {
            Double Qty = Convert.ToDouble(txtItemQty.Text);
            if (Qty <= 0)
            {
                DisplayError = DisplayError + "--" + " Item Quantity to be numeric and greater than 0  . ";
                Error = 1;
            }
        }
        catch
        {
            DisplayError = DisplayError + "--" + " Item Quantity to be numeric  . ";
            Error = 1;
        }
        try
        {
            if (txtWastage.Text == "")
            {
                txtWastage.Text = "0";
            }
            else
            {
                Double Wastage = Convert.ToDouble(txtWastage.Text);
                if (Wastage < 0)
                {
                    DisplayError = DisplayError + "--" + " Wastage to be numeric and Positive number  . ";
                    Error = 1;
                }
            }

        }
        catch
        {
            DisplayError = DisplayError + "--" + " Wastage to be numeric  . ";
            Error = 1;
        }
        int DupItemKount = 0;
        foreach (GridViewRow gvr in grdIOWItem.Rows)
        {
            if (((Label)gvr.FindControl("lblItemId")).Text == (ddlItem.SelectedValue))
            {
                DupItemKount = DupItemKount + 1;
            }
        }
        if (DupItemKount > 0)
        {
            DisplayError = DisplayError + "--" + " Item Getting Added is Already Available in the Grid..Pls Select Some other Item  . ";
            Error = 1;
        }
        if (Error == 1)
        {
            ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + DisplayError + "');", true);
        }
        return Error;
    }




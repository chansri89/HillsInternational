    private void LoadGridIOW(Int32 TemCompanyId)//To load data into grid.
    {
        IOWMsg iow = new IOWMsg();
        iow.CompanyId = TemCompanyId;
        iow.Flag = "R";
        IOWList = Bus.MasIOWInsertUpdate(iow);
        IOWFilter(IOWList);
    }
    private void IOWFilter(List<IOWMsg> IOwlst)
    {

        List<IOWMsg> FIOWList = new List<IOWMsg>();
        if (txtFilter.Text.Trim().Length == 0)
        {
            FIOWList = IOwlst.ToList();
        }
        else
        {
            foreach (IOWMsg cm in IOwlst)
            {
                if (cm.IOWName.ToUpper().Contains(txtFilter.Text.Trim().ToUpper()))
                {
                    FIOWList.Add(cm);
                }
            }
        }
        if (IOwlst.Count == 0)
        {
            ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + "No IOW for the Filter Found .." + "');", true);
            FIOWList = IOwlst.ToList();
        }
        GrdIOWMaster.DataSource = "";
        GrdIOWMaster.DataSource = FIOWList;
        GrdIOWMaster.DataBind();
        Pnlgv.Visible = true;
        pnlAdd.Visible = true;
        pnlIOWItem.Visible = false;
        pnlIOWitemAdd.Visible = false;
    }
    private void IOWSave()
    {
        WCompanyId = Convert.ToInt32(ddlCompany.SelectedValue);
        IOWMsg Cmp = new IOWMsg();
        if (btnSave.Text.ToUpper() == "SAVE")
        {
            Cmp.Flag = "I";
            Cmp.IsActive = true;
        }
        else
        {
            Cmp.Flag = "U";
            Cmp.IsActive = Cmp.IsActive;
        }
        Cmp.CompanyId = Convert.ToInt32(ddlCompany.SelectedValue); //WCompanyId;
        Cmp.PackageCode = ddlPackage.SelectedValue; //scs 220217 introduced
        Cmp.TradeCode = ddlTrade.SelectedValue;
        Cmp.ElementCode = ddlElement.SelectedValue;

        Cmp.IOWCode = txtIOWCode.Text.Trim();
        Cmp.IOWName = txtIOWName.Text.Trim();
        Cmp.IOWUOM = txtIOWUOM.Text.Trim();
        Cmp.IOWShortName = txtIOWShortName.Text.Trim();
        Cmp.IOWQuantity = Convert.ToDouble(txtIOWQuantity.Text.Trim());
        Cmp.IsCommonFactorsApplicable = ChkIsCommonfactorsApplicable.Checked;
        Cmp.IsTemproryIOW = ChkIsTemproryIOW.Checked;



        Cmp.CreatedBy = BaseMsg.EmployeeCode;
        IOWList = Bus.MasIOWInsertUpdate(Cmp);
        //Output Dispay
        foreach (IOWMsg cmp in IOWList)
        {
            if (cmp.Result == "0")
            {
                ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + AgilerMail.SuccessFullySaved + "');", true);
                AllClear();
                //pnlPendind.Enabled = false;
                txtIOWCode.Enabled = true;
                btnSave.Text = "Save";
                break;

            }
            else
            {
                ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + cmp.Result + "');", true);
                break;
            }
        }
    }

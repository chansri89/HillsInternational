    #region Methods
    #region IOW
    private void LoadCompany()
    {
        CmpList = Bus.CompanyMasterSelect();
        if (BaseMsg.IsAdmin == false)
        {
            CmpList = (from cmp in CmpList where cmp.CompanyId == BaseMsg.CompanyId select cmp).ToList();
        }
        if (CmpList != null && CmpList.Count > 0)
        {
            ddlCompany.DataSource = CmpList;
            ddlCompany.DataBind();
            ddlCompany.Items.Insert(0, "--Select Please--");
            ddlCompany.SelectedIndex = 0;
            if (CmpList.Count == 1)
            {
                ddlCompany.SelectedIndex = 1;
                ddlCompany.Enabled = false;
                WCompanyId = Convert.ToInt32(ddlCompany.SelectedValue);
                LoadGridIOW(WCompanyId);
            }
            else
            {
                ddlCompany.Enabled = true;
            }

        }
        else
        {
            ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + AgilerMail.ErrCompanyData + "');", true);
            // ddlCompany.Items.Insert(0, "--Select Please--");
        }
        txtIOWCode.Enabled = true;
    }
    private void LoadPackage()
    {
        string EmpCode = BaseMsg.EmployeeCode;
        PackageMasterMsg pkmsg = new PackageMasterMsg();
        pkmsg.Flag = "R";
        pklst = Bus.MasCRAMPackageInsertandUpdate(pkmsg);
        if (pklst != null && pklst.Count > 0)
        {
            ddlPackage.DataSource = pklst;
            ddlPackage.DataBind();
            ddlPackage.Items.Insert(0, "--Select Please--");
            ddlPackage.SelectedIndex = 0;
            ddlPackage.Enabled = true;
        }
        else
        {
            ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + "IOW Package master Not Available" + "');", true);
            // ddlCompany.Items.Insert(0, "--Select Please--");
        }
        
    }
    private void LoadTrade()
    {
        string EmpCode = BaseMsg.EmployeeCode;
        TradeMasterMsg trmsg = new TradeMasterMsg();
        trmsg.Flag = "R";
        Trlst = Bus.MasCRAMTradeInsertUpdate(trmsg);
        if (Trlst != null && Trlst.Count > 0)
        {
            ddlTrade.DataSource = Trlst;
            ddlTrade.DataBind();
            ddlTrade.Items.Insert(0, "--Select Please--");
            ddlTrade.SelectedIndex = 0;
            ddlTrade.Enabled = true;
        }
        else
        {
            ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + "IOW Trade master Not Available" + "');", true);
            // ddlCompany.Items.Insert(0, "--Select Please--");
        }

    }

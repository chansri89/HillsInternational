    <asp:panel ID="Pnlgv" runat="server" Width="1165px" Height="308px" 
            ToolTip="Click on IOW Name row to Edit and update">
        <div id="divIOW" runat="server"  
            style="overflow:auto; height:302px; width:1149px">

    <asp:GridView ID="GrdIOWMaster" runat="server" CellPadding="3" 
            Font-Size="XX-Small" Width="1128px" Font-Names="Verdana" AutoGenerateColumns="False" 
            Height="16px" GridLines="Vertical" BorderColor="#999999" BorderStyle="None" BorderWidth="1px" 
            OnRowCommand="GrdIOW_RowCommand">
               <%-- onrowcancelingedit="GrdIOWMaster_RowCancelingEdit"   
                onrowediting="GrdIOWMaster_RowEditing" BackColor="White" --%>
                <%--onrowupdating="GrdIOWMaster_RowUpdating"--%> 


        <EditRowStyle Font-Size="XX-Small" />
        <FooterStyle BackColor="#CCCCCC" ForeColor="Black" />
        <RowStyle BackColor="#EEEEEE" ForeColor="Black" />
        <PagerStyle BackColor="#999999" ForeColor="Black" HorizontalAlign="Center" />
        <SelectedRowStyle BackColor="#008A8C" Font-Bold="True" ForeColor="White" />
        <HeaderStyle BackColor="#000084" Font-Bold="True" ForeColor="White" 
            HorizontalAlign="Left" />
        <AlternatingRowStyle BackColor="#DCDCDC" />

       
        <Columns>
            <asp:TemplateField HeaderText="CompanyId"  Visible="false">
            <ItemTemplate>
            <asp:Label ID="lblCompanyId" runat="server" Text='<%# Eval("CompanyId") %>'  Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
             <HeaderStyle Width="10px" />
            </asp:TemplateField>
 

           <asp:TemplateField HeaderText="Package Code" Visible="false">
            <ItemTemplate>
            <asp:Label ID="lblPackageCode" runat="server" Text='<%# Eval("PackageCode") %>'  Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
              <HeaderStyle Width="50px"/><ItemStyle Width = "50px" />
               </asp:TemplateField>
            <asp:TemplateField HeaderText="Package Name" Visible="true">
            <ItemTemplate>
            <asp:Label ID="lblPackageName" runat="server" Text='<%# Eval("PackageName") %>'  Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
              <HeaderStyle Width="30px"/><ItemStyle Width = "30px" />
               </asp:TemplateField>
 
            <asp:TemplateField HeaderText="Trade Code" Visible="false">
            <ItemTemplate>
            <asp:Label ID="lblTradeCode" runat="server" Text='<%# Eval("TradeCode") %>'  Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
              <HeaderStyle Width="50px"/><ItemStyle Width = "50px" />
               </asp:TemplateField>

          <asp:TemplateField HeaderText="Trade Name" Visible="true">
             <ItemTemplate>
            <asp:Label ID="lblTradeName" runat="server" Text='<%# Eval("TradeName") %>'   Width="40px" Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
                <HeaderStyle Width="40px" />
            </asp:TemplateField>
            <asp:TemplateField HeaderText="Element Code" Visible="false">
            <ItemTemplate>
            <asp:Label ID="lblElementCode" runat="server" Text='<%# Eval("elementCode") %>'  Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
              <HeaderStyle Width="50px"/><ItemStyle Width = "50px" />
               </asp:TemplateField>
            <asp:TemplateField HeaderText="Element Name" Visible="true">
             <ItemTemplate>
            <asp:Label ID="lblElementName" runat="server" Text='<%# Eval("ElementName") %>'   Width="30px" Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
                <HeaderStyle Width="30px" />
            </asp:TemplateField>
           <asp:TemplateField HeaderText="IOW Code" Visible="true">
            <ItemTemplate>
            <asp:Label ID="lblIOWCode" runat="server" Text='<%# Eval("IOWCode") %>' Width="30px" Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
              <HeaderStyle Width="30px"/>
            </asp:TemplateField>

            <asp:TemplateField HeaderText="IOW Name" Visible="false">
            <ItemTemplate>
            <asp:Label ID="lblIOWName" runat="server" Text='<%# Eval("IOWName") %>'  Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
              <HeaderStyle Width="50px"/><ItemStyle Width = "50px" />
               </asp:TemplateField>
 
         <asp:TemplateField HeaderText="Click IOW Name for Update" Visible="true" >
            <ItemTemplate>  
            <asp:LinkButton ID="lnkCustName" Width="550px" runat ="server" CommandArgument='<%#Eval("IOWCode")%>'
             CommandName ="UpdateIOW" Text ='<%#Eval("IOWName") %>'></asp:LinkButton>
              </ItemTemplate> <HeaderStyle Width="550px" />
            </asp:TemplateField>
           <asp:TemplateField HeaderText="IOW Sh.Name" Visible="True">
            <ItemTemplate>
            <asp:Label ID="lblIOWShortName" runat="server" Text='<%# Eval("IOWShortName") %>'  Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
              <HeaderStyle Width="50px"/><ItemStyle Width = "50px" />
               </asp:TemplateField>

           
            <asp:TemplateField HeaderText="IOW UOM">
             <ItemTemplate>
            <asp:Label ID="lblIOWUOM" runat="server" Text='<%# Eval("IOWUOM") %>' Width="30px" Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
                <HeaderStyle Width="30px" />
            </asp:TemplateField>
             <asp:TemplateField HeaderText="IOW Qty" Visible="true">
             <ItemTemplate>
            <asp:Label ID="lblIOWQuantity" runat="server" Text='<%# Eval("IOWQuantity") %>'   Width="30px" Font-Names="Verdana" Font-Size="XX-Small"></asp:Label></ItemTemplate>
                <HeaderStyle Width="30px" /><ItemStyle Width = "40px" HorizontalAlign="Right" />
            </asp:TemplateField>

             <asp:TemplateField HeaderText="Is Temprory IOW">
             <ItemTemplate>
              <asp:CheckBox ID="chkTemproryIOW" runat="server" Checked='<%# Eval("IsTemproryIOW") %>'
            Font-Names="Verdana" Font-Size="XX-Small" Width="30px" Enabled="false"></asp:CheckBox>
             </ItemTemplate>
                <HeaderStyle Width="30px" />
                <ItemStyle HorizontalAlign="Center" />
            </asp:TemplateField>

              <asp:TemplateField HeaderText="Is Comm FactAppl">
             <ItemTemplate>
              <asp:CheckBox ID="chkIsCommonFactorsApplicable" runat="server" Checked='<%# Eval("IsCommonFactorsApplicable") %>'
            Font-Names="Verdana" Font-Size="XX-Small" Width="30px" Enabled="false"></asp:CheckBox>
             </ItemTemplate>
                <HeaderStyle Width="30px" />
                <ItemStyle HorizontalAlign="Center" />
            </asp:TemplateField>
        <asp:TemplateField HeaderText="Click IowItem" Visible="true" >
            <ItemTemplate>  
            <asp:LinkButton ID="lnkIOWItemName" Width="60px" runat ="server" CommandArgument='<%#Eval("IOWCode")%>'
             CommandName ="IOWItem" Text ="IOW Item"></asp:LinkButton>
              </ItemTemplate> <HeaderStyle Width="60px" />
            </asp:TemplateField>
            
        </Columns>
        <sortedascendingcellstyle backcolor="#F1F1F1" />
        <sortedascendingheaderstyle backcolor="#0000A9" />
        <sorteddescendingcellstyle backcolor="#CAC9C9" />
        <sorteddescendingheaderstyle backcolor="#000065" />
    </asp:GridView>
    </div>
    <%--</td>
    </tr>--%>
    </asp:panel>

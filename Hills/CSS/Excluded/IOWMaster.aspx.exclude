    <asp:Panel ID="pnlPendind" runat="server" Height="28px" Width="562px">
        <table style="height: 22px; width: 380px;">
            <tr>
                      <td class="style28" style="width: 70px">
                <asp:Label ID="lblCompany" runat="server" Text="Company" Visible="true"
                  Font-Bold="true"  Font-Names="Arial" Font-Size="Small" ></asp:Label>
           </td>
             <td style="width: 100px" class="style21">
                <asp:DropDownList ID="ddlCompany"  runat="server"  Visible="true"
                    Font-Names="Arial" DataTextField="CompanyName" DataValueField="CompanyId"
                    Style="font-size: X-Small" Width="248px"  AutoPostBack="true" 
                     OnSelectedIndexChanged="ddlCompanyChanged" Height="16px"  >
                 </asp:DropDownList>
            </td>
                <td class="style28" style="width: 70px">
                <asp:Label ID="lblFilter" runat="server" Text="Filter" Visible="true"
                  Font-Bold="true"  Font-Names="Arial" Font-Size="X-Small" ></asp:Label>
           </td>

            <td class="style28" style="width: 70px">
                <asp:TextBox ID="txtFilter" runat="server" Text="" Visible="true"
                  Font-Bold="true"  Font-Names="Arial" Font-Size="X-Small" ></asp:TextBox>
           </td>
                <td class="style28" style="width: 62px" >
                         <asp:Button ID="btnFilter" runat="server" Font-Names="Verdana" Font-Size="X-Small" 
                               Height="21px" onclick="btnFilter_Click"  style="font-size: X-small; font-family: 'Times New Roman', Times, serif; font-weight: 700;" 
                               Text="Filter" Width="43px" />
                 </td>      
                             
            </tr>
               
        </table>

    #region Method
    private void LoadDepot()
    {
        string CompCode = ddlCompany.SelectedValue;
        string EmpCode = BaseMsg.EmployeeCode;
        //DepList = Bus.NewDepotMasterSelect(EmpCode);
        //DepList = (from dp in DepList where dp.LocationType == "A" select dp).ToList(); //scs 201020 scs changed  picking it from tblLocations
        DepList = (from dp in DepList where (dp.LocationType == "A" && dp.CompanyCode == CompCode) select dp).ToList(); //scs 201020 scs changed  picking it from tblLocations
        if (DepList != null && DepList.Count > 0)
        {
            ddlAuctionLocation.DataSource = DepList;
            ddlAuctionLocation.DataBind();
            ddlAuctionLocation.Items.Insert(0, "--Select Please--");
            ddlAuctionLocation.SelectedIndex = 0;
            ddlAuctionLocation.Enabled = true;
        }
        else
        {
            ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + AgilerMail.ErrCenterData + "');", true);
            ddlAuctionLocation.Items.Insert(0, "--Select Please--");
        }
    }
    private void LoadClient()
    {
        CmpList = Bus.CompanyMasterSelect();

        if (CmpList != null && CmpList.Count > 0)
        {
            ddlCompany.DataSource = CmpList;
            ddlCompany.DataBind();
            ddlCompany.Items.Insert(0, "--Select Please--");
            ddlCompany.SelectedIndex = 0;
        }
        else
        {
            ScriptManager.RegisterStartupScript(this, typeof(string), "Alert", "alert('" + "Client Data not Found" + "');", true);
           // ddlCompany.Items.Insert(0, "--Select Please--");
        }
    }

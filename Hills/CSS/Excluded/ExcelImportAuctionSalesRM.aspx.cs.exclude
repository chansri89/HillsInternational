    public List<ExcelUploadMsg> SalesRelatedUpLoad(DataTable dtCoup,string TranType)
    {
        System.Globalization.DateTimeFormatInfo dateinfo = new System.Globalization.DateTimeFormatInfo();
        dateinfo.ShortDatePattern = "MM-dd-yyyy";
        lblMessage.Text = TranType+ " UpLoad Method Running";
        List<ExcelUploadMsg> excelUploadList = new List<ExcelUploadMsg>();
        int linecount = 1; // if in excel connection string HDR is Yes the Hdr is taken care hence 1 else 0
        foreach (DataRow dr in dtCoup.Rows)
        {
            string CompCode = ddlCompany.SelectedValue;
            string LocationCode = ddlAuctionLocation.SelectedValue;
           // string WDate = "";             string WChar = ""; string sDate = "";
            int err = 1; // set for error condition reset only if valid data below scs vj 200923
            if (linecount >= 1) // first row contains heading in xl
            {
                 ExcelUploadMsg excelUpload = new ExcelUploadMsg();
                 #region RM AUCTIOnFormat
                 if ((dr[22].ToString() != string.Empty && dr[4].ToString() != string.Empty && dr[5].ToString() != string.Empty))
                 //GSTIN InvNo,InvDate and date and qty should not be empty hence neglect that row
                 {
                     excelUpload.Column1 = dr[0].ToString() == null ? string.Empty : dr[0].ToString(); // Season                    
                     //WDate = excelUpload.Column1.Replace("/", "-"); // taking it as date as Integer
                     //sDate = (Convert.ToDateTime(WDate)).ToString("MM-dd-yyyy");
                     //excelUpload.Column1 = sDate;
                     excelUpload.Column2 = dr[1].ToString() == null ? string.Empty : dr[1].ToString(); // SaleNO
                     //WDate = excelUpload.Column2.Replace("/", "-");
                     //sDate = (Convert.ToDateTime(WDate)).ToString("MM-dd-yyyy");
                     //excelUpload.Column2 = sDate;
                     excelUpload.Column3 = dr[2].ToString() == null ? string.Empty : dr[2].ToString(); //saledate
                     excelUpload.Column4 = dr[3].ToString() == null ? string.Empty : dr[3].ToString(); //DOCType
                     excelUpload.Column5 = dr[4].ToString() == null ? string.Empty : dr[4].ToString(); //INVNO
                     excelUpload.Column6 = dr[5].ToString() == null ? string.Empty : dr[5].ToString(); //INVdt
                     excelUpload.Column7 = dr[6].ToString() == null ? string.Empty : dr[6].ToString(); // inv seller         
                     excelUpload.Column8 = dr[7].ToString() == null ? string.Empty : dr[7].ToString(); //supp add
                     excelUpload.Column9 = dr[8].ToString() == null ? string.Empty : dr[8].ToString(); //city
                     excelUpload.Column10 = dr[9].ToString() == null ? string.Empty : dr[9].ToString(); //statecode

                     excelUpload.Column11 = dr[10].ToString() == null ? string.Empty : dr[10].ToString(); //pincode
                     excelUpload.Column12 = (dr[11].ToString() == null || dr[11].ToString() == string.Empty) ? "" : dr[11].ToString(); //SoldPsellerphrice
                     excelUpload.Column13 = (dr[12].ToString() == null || dr[12].ToString() == string.Empty) ? "" : dr[12].ToString(); //selleremail
                     excelUpload.Column14 = dr[13].ToString() == null ? "" : dr[13].ToString(); // sellerGSTIN
                     excelUpload.Column15 = dr[14].ToString() == null ? "" : dr[14].ToString(); // buyername
                     excelUpload.Column16 = dr[15].ToString() == null ? "" : dr[15].ToString(); // buyeradd1
                     excelUpload.Column17 = (dr[16].ToString() == null) ? "" : dr[16].ToString(); // buyeradd2
                     excelUpload.Column18 = dr[17].ToString() == null ? string.Empty : dr[17].ToString(); //salebuyerciy1

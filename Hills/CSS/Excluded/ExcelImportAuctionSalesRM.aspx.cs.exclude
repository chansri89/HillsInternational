    private List<RMSalesMsg> CheckData(List<ExcelUploadMsg> ExData, string TranType)
    {
        System.Globalization.DateTimeFormatInfo dateinfo = new System.Globalization.DateTimeFormatInfo();
        dateinfo.ShortDatePattern = "dd/MM/yyyy";

        lblMessage.Text = "CheckData Method Running";
        List<RMSalesMsg> DataErr = new List<RMSalesMsg>();
       
            int RCount = 0; //Since XL has column Heading, the rownumber to start from 2
            ChkResult = 0; // set OK
            foreach (ExcelUploadMsg ExMsg in ExData)
            {
                RMSalesMsg dtMsg = new RMSalesMsg();
                int ChkResult1 = 0;
                try
                {
                    RCount = RCount + 1;
                    string RKount = Convert.ToString(RCount);
                    dtMsg.RKount = RKount;
                    #region DepSale
                    //if (TranType == "AUCTION SALES" && ddlAuctionLocation.SelectedIndex == 0)
                    //{
                   
                        try
                        {
                            DateTime SaleDate = Convert.ToDateTime(ExMsg.Column3, dateinfo);
                            DateTime InvDate = Convert.ToDateTime(ExMsg.Column6, dateinfo);
                        }
                        catch
                        {
                            dtMsg.Result = dtMsg.Result + " - Invoice Date or Sale Date format not proper  ";
                            ChkResult1 = 1;
                        }
                   
                    dtMsg.SaleDate = ExMsg.Column3;
                    dtMsg.DocType = ExMsg.Column4;
                    dtMsg.InvoiceNo = (ExMsg.Column5);
                    dtMsg.InvoiceDate = (ExMsg.Column6);
                    dtMsg.INVIssuer = (ExMsg.Column7);
                    dtMsg.SuppAdd1 = (ExMsg.Column8);
                    dtMsg.SuppCity = (ExMsg.Column9);

                    dtMsg.SuppStCode = ExMsg.Column10;

                    try
                    {
                        Int64 Pin = Convert.ToInt64(ExMsg.Column11);
                        dtMsg.SuppPinCode = (ExMsg.Column11);
                    }
                    catch
                    {
                        dtMsg.Result = dtMsg.Result + " - Pincode to be numeric ";
                        ChkResult1 = 1;
                   
                    }
                    dtMsg.SuppPhone = (ExMsg.Column12);
                    dtMsg.SuppEmail = (ExMsg.Column13);
                    dtMsg.SuppGSTNo = (ExMsg.Column14);

                    
                    dtMsg.BuyerName = (ExMsg.Column15);
                    dtMsg.BuyerAdd1 = (ExMsg.Column16);
                        dtMsg.BuyerAdd2 = (ExMsg.Column17); // 
                        dtMsg.BuyerCity = (ExMsg.Column18);
                        dtMsg.BuyerStCode =(ExMsg.Column19); //
                        dtMsg.BuyerPincode = (ExMsg.Column20); //
                        dtMsg.BuyerPhone = (ExMsg.Column21); //
                        dtMsg.BuyerEmail = (ExMsg.Column22); //
                        if (ExMsg.Column20 == "")
                        {
                            dtMsg.Result = dtMsg.Result + " - Buyer GSTIN Mandatory ";
                            ChkResult1 = 1;
                        }
                        dtMsg.BuyerGSTIN = (ExMsg.Column23); //
                        dtMsg.POS = (ExMsg.Column24); //
                        dtMsg.SrlNo = Convert.ToInt32(ExMsg.Column25);
                        dtMsg.LotNo = (ExMsg.Column26); //
                        dtMsg.Goods = (ExMsg.Column27); //
                        dtMsg.HSNCode = (ExMsg.Column28); //
                        if (ExMsg.Column29 == "0")
                        {
                            dtMsg.Result = dtMsg.Result + " - NetKGs cannot be 0 ";
                            ChkResult1 = 1;
                        }
                        else
                        {
                            dtMsg.NetKgs = Convert.ToDouble(ExMsg.Column29);
                        }

                        dtMsg.DealPrice = Convert.ToDouble(ExMsg.Column30);
                        dtMsg.GrossAmt = Convert.ToDouble(ExMsg.Column31);
                        dtMsg.NetAmt = Convert.ToDouble(ExMsg.Column32);
                        dtMsg.GSTRate = Convert.ToDouble(ExMsg.Column33);
                        dtMsg.IGSTAmt = Convert.ToDouble(ExMsg.Column34);
                        dtMsg.CGSTAmt = Convert.ToDouble(ExMsg.Column35);
                        dtMsg.SGSTAmt = Convert.ToDouble(ExMsg.Column36);
                        dtMsg.ItemTotAmt = Convert.ToDouble(ExMsg.Column37);
                        dtMsg.TotalTaxableAmt = Convert.ToDouble(ExMsg.Column38);
                        dtMsg.TotSGSTVal = Convert.ToDouble(ExMsg.Column39);
                        dtMsg.TotCGSTVal = Convert.ToDouble(ExMsg.Column40);
                        dtMsg.TotIGSTVal = Convert.ToDouble(ExMsg.Column41);
                    //
                        dtMsg.TotInvAmt = Convert.ToDouble(ExMsg.Column42);
                        dtMsg.SignedIRN = (ExMsg.Column43);
                        dtMsg.AckNo = (ExMsg.Column44);
                        dtMsg.AckDt = (ExMsg.Column45);
                        dtMsg.Status = (ExMsg.Column46);
                    
                    // }
                #endregion

                    if (ChkResult1 != 1)
                    {
                        dtMsg.Result = "OK";
                    }
                }
                catch //(Exception ex)
                {
                    ChkResult1 = 1;
                    dtMsg.Result = "Invalid character or Spaces in fields having numeric value";
                }
                ChkResult = ChkResult + ChkResult1;
                ChkResult1 = 0; //reset 
                DataErr.Add(dtMsg);
            }
        
        
        return DataErr;
    }

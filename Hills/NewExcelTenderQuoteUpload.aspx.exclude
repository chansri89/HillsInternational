    <div style="height: 95px; width: 1237px;">
    <table id="tblFileType" runat="server" style="width: 1222px; height: 47px;">
        <tr>
 
            <td>
                <asp:Label ID="lblCompany" runat="server" Text="Company" Visible="true"
                  Font-Bold="true"  Font-Names="Arial" Font-Size="X-Small" ></asp:Label>
           </td>
             <td>
                <asp:DropDownList ID="ddlCompany"  runat="server"  Visible="true"
                    Font-Names="Arial" DataTextField="CompanyName" DataValueField="CompanyId"
                    Style="font-size: X-Small" Width="138px" AutoPostBack="true" 
                     OnSelectedIndexChanged="ddlCompanyChanged" height="16px" >
                 </asp:DropDownList>
            </td>

           <td>
                <asp:Label ID="lblTransType" runat="server" Text="Tenderer" Visible="true"
                  Font-Bold="true"  Font-Names="Arial" Font-Size="X-Small" ></asp:Label>
           </td>
             <td>
                <asp:DropDownList ID="ddlClient"  runat="server"  Visible="true" 
                    Font-Names="Arial" DataTextField="ClientName" DataValueField="ClientCode"
                    Style="font-size: X-Small" Width="122px" height="19px"  >
                 </asp:DropDownList>
            </td>

           <td>
                <asp:Label ID="lblProject" runat="server" Text="Project" Visible="true"
                  Font-Bold="true"  Font-Names="Arial" Font-Size="X-Small" ></asp:Label>
           </td>
             <td>
                <asp:DropDownList ID="ddlProject"  runat="server"  Visible="true"
                    Font-Names="Arial" DataTextField="ProjectName" DataValueField="ProjectCode"
                    AutoPostBack="true" OnSelectedIndexChanged="ddlProjectChanged"
                    Style="font-size: X-Small" Width="119px" height="22px"  >
                 </asp:DropDownList>
            </td>
             <td> 
                <asp:CheckBox ID = "ChkBudget" runat="server" Checked="false" enabled = "false" Font-Size="X-Small" Text="Is Budget" />
            </td>

   <%--                    <td>
                <asp:Label ID="lblQuote" runat="server" Text="Tender" Visible="true"
                  Font-Bold="true"  Font-Names="Arial" Font-Size="X-Small" ></asp:Label>
           </td>
             <td>
                <asp:DropDownList ID="ddlQuote"  runat="server"  Visible="true"
                    Font-Names="Arial" DataTextField="TenderUpLoadType" DataValueField="TenderUpLoadValue"
                    Style="font-size: X-Small" Width="72px" height="20px"  >

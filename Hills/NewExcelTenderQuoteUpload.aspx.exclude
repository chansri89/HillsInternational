                     <asp:ListItem Text="Tenderer Quote" Value="3" />
                    

                 </asp:DropDownList>
            </td>--%>

            
            <td>
                <asp:Label ID="lblFileUpload" runat="server" Text="File Path: " 
                  Font-Bold="true"  Font-Names="Arial" Font-Size="X-Small" ></asp:Label>
            </td>
            <td>
                <asp:FileUpload ID="FlUpdExcel" runat="server" Width="231px" Height="21px" 
                    Font-Names="Arial" Font-Size="X-Small"/>
            </td>
            <td>
                <asp:Button ID="btnUpload" runat="server" Font-Names="Arial" Font-Size="X-Small" 
              ForeColor="Black" BackColor="LightBlue" OnClick="btnUpload_Click" Text="Upload" Width="50px" 
              TabIndex="16" />
            </td>
  <%--      <td style="width: 43px" >
                <asp:Label ID="lblAuctionFormat" runat="server" Text="Auction Format" Visible="false"
                  Font-Bold="true"  Font-Names="Arial" Font-Size="X-Small" ></asp:Label>
           </td>
             <td >
